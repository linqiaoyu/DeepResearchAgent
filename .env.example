# LLM/search keys are optional for the deterministic local MVP.
# Add real providers when replacing FixtureSearchTool and mock LLM agents.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPRESEARCH_SEARCH_PROVIDER=fixture
TAVILY_API_KEY=
SERPER_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Local default. Docker mounts /app/data/runtime for this path.
DEEPRESEARCH_STORAGE_PATH=data/runtime/research.db
DEEPRESEARCH_MAX_CRITIC_ITER=3
DEEPRESEARCH_TOKEN_BUDGET=200000
