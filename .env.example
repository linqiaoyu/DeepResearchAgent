# LLM/search keys. Deterministic mode does not require keys.
# LLM mode requires DEEPSEEK_API_KEY and reads it only from .env.
DEEPRESEARCH_SEARCH_PROVIDER=fixture
DEEPRESEARCH_MODE=deterministic
DEEPSEEK_API_KEY=

# Reserved for later provider tasks; not used by the default deterministic MVP.
DASHSCOPE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Local default. Docker mounts /app/data/runtime for this path.
DEEPRESEARCH_STORAGE_PATH=data/runtime/research.db
DEEPRESEARCH_MAX_CRITIC_ITER=3
DEEPRESEARCH_TOKEN_BUDGET=200000
DEEPRESEARCH_LLM_BUDGET_CNY=3.0
DEEPRESEARCH_LLM_LEDGER_PATH=data/runtime/llm_ledger.jsonl
DEEPRESEARCH_LLM_MAX_SUB_QUESTIONS=3
DEEPRESEARCH_LLM_MAX_QUERIES_PER_SUB_QUESTION=3
